{
  "manifest_version": 3,
  "name": "YT Downloader BETA (Edge)",
  "version": "1.0.0",
  "description": "Télécharge des vidéos YouTube en un clic avec YT Downloader, THIS EXTENSION IS FOR BETA TESTING",
  "permissions": [],
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://music.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}