{
  "name": "youtube-downloader",
  "version": "1.4.0",
  "author": "YT Downloader",
  "description": "Personal YouTube downloader - MP3 & MP4",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build": "electron-builder --win",
    "build mac": "electron-builder --mac",
    "build linux": "electron-builder --linux",
    "build:dir": "electron-builder --win --dir",
    "dist": "electron-builder --win --publish never"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.ytdownloader.app",
    "productName": "YT Downloader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/img/youtube-downloader.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/img/youtube-downloader.ico",
      "uninstallerIcon": "public/img/youtube-downloader.ico",
      "installerHeaderIcon": "public/img/youtube-downloader.ico"
    }
  },
  "private": true
}